<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".SerialFragment">

    <!-- Back Button -->
    <Button
        android:id="@+id/buttonBack"
        style="?android:attr/buttonBarButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="@string/button_back"
        android:backgroundTint="#757575"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:layout_margin="8dp" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/title_glass_setup"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:gravity="start"
                android:padding="4dp"
                android:layout_marginBottom="8dp" />

            <!-- Patient Info Display -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPatientInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E8F5E9">

                <TextView
                    android:id="@+id/textPatientInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp" />

            </androidx.cardview.widget.CardView>

            <!-- USB Configuration Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_serial_settings"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="10dp" />

                    <!-- Device Selection -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="@string/label_device"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:paddingTop="6dp" />

                        <Spinner
                            android:id="@+id/spinnerDevice"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:background="@android:drawable/editbox_background"
                            android:popupBackground="@android:color/white" />

                        <Button
                            android:id="@+id/buttonRefresh"
                            android:layout_width="48dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="4dp"
                            android:backgroundTint="#2196F3"
                            android:padding="0dp"
                            android:text="@string/button_refresh"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <!-- Baud Rate -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="wrap_content"
                            android:text="@string/label_baud"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:paddingTop="6dp" />

                        <Spinner
                            android:id="@+id/spinnerBaudRate"
                            android:layout_width="0dp"
                            android:layout_height="32dp"
                            android:layout_weight="1"
                            android:background="@android:drawable/editbox_background"
                            android:popupBackground="@android:color/white" />
                    </LinearLayout>

                    <!-- Data, Stop, Parity -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:layout_marginEnd="3dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="wrap_content"
                                android:text="@string/label_data"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingTop="8dp" />

                            <Spinner
                                android:id="@+id/spinnerDataBits"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:background="@android:drawable/editbox_background"
                                android:popupBackground="@android:color/white" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:layout_marginStart="3dp"
                            android:layout_marginEnd="3dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="wrap_content"
                                android:text="@string/label_stop"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingTop="8dp" />

                            <Spinner
                                android:id="@+id/spinnerStopBits"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:background="@android:drawable/editbox_background"
                                android:popupBackground="@android:color/white" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:layout_marginStart="3dp">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="wrap_content"
                                android:text="@string/label_parity"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:paddingTop="8dp" />

                            <Spinner
                                android:id="@+id/spinnerParity"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:background="@android:drawable/editbox_background"
                                android:popupBackground="@android:color/white" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- USB Control Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        style="?android:attr/buttonBarStyle">

                        <Button
                            android:id="@+id/buttonConnect"
                            style="?android:attr/buttonBarButtonStyle"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:text="@string/button_connect"
                            android:enabled="false"
                            android:layout_marginEnd="4dp"
                            android:textSize="13sp"
                            android:backgroundTint="#4CAF50"
                            android:textColor="#FFFFFF" />

                        <Button
                            android:id="@+id/buttonDisconnect"
                            style="?android:attr/buttonBarButtonStyle"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:text="@string/button_disconnect"
                            android:layout_marginStart="4dp"
                            android:textSize="13sp"
                            android:backgroundTint="#F44336"
                            android:textColor="#FFFFFF" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_data_actions"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        style="?android:attr/buttonBarStyle">

                        <Button
                            android:id="@+id/buttonPlot"
                            style="?android:attr/buttonBarButtonStyle"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="@string/button_plot"
                            android:textSize="13sp"
                            android:backgroundTint="#9C27B0"
                            android:textColor="#FFFFFF" />

                        <Button
                            android:id="@+id/buttonStorageManager"
                            style="?android:attr/buttonBarButtonStyle"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="@string/button_storage"
                            android:textSize="13sp"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Status Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#E3F2FD">

                <TextView
                    android:id="@+id/textStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:text="@string/status_ready"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:gravity="center" />

            </androidx.cardview.widget.CardView>

            <!-- Stats Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF9C4">

                <TextView
                    android:id="@+id/textStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="@string/stats_packets"
                    android:textSize="11sp"
                    android:textColor="#795548"
                    android:gravity="center" />

            </androidx.cardview.widget.CardView>

            <!-- Data Display Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="300dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/data_received"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:textColor="#333333"
                            android:layout_gravity="center_vertical" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <Button
                            android:id="@+id/buttonToggleView"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Switch to Graph"
                            android:textSize="11sp"
                            android:backgroundTint="#2196F3"
                            android:textColor="#FFFFFF"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </LinearLayout>

                    <!-- Data Display TextView -->
                    <TextView
                        android:id="@+id/textDataDisplay"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fontFamily="monospace"
                        android:padding="6dp"
                        android:text="@string/data_ready"
                        android:textSize="11sp"
                        android:textColor="#333333"
                        android:background="#FAFAFA"
                        android:inputType="textMultiLine"
                        android:scrollbars="vertical"
                        android:maxLines="100"
                        android:isScrollContainer="true"
                        android:overScrollMode="always" />

                    <!-- Graph Container -->
                    <FrameLayout
                        android:id="@+id/graphContainer"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        android:background="#FFFFFF">

                        <com.github.mikephil.charting.charts.LineChart
                            android:id="@+id/lineChart"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>